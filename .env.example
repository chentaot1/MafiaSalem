# Copy to .env and fill in for your server.

DISCORD_TOKEN=

# Required for production (single-server lock)
ALLOWED_GUILD_ID=

# Discord resource IDs (override config.py defaults)
PLAYING_ROLE_ID=
GAME_CATEGORY_ID=
GAME_OVERSEER_ROLE_ID=

# Optional
TRIBUNAL_RESUME_MIN_SECONDS=30
MAFIABOT_STRICT_CONFIG=0
MAFIABOT_ALLOW_MULTI=0
# MAFIABOT_STATE_DIR=C:\path\to\state
